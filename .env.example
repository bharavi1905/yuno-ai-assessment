# LLM
# OpenAI API key — required for all agent LLM calls (GPT-4o / GPT-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# Database
# PostgreSQL connection — host must match the docker-compose service name
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agent_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
# Redis connection — host must match the docker-compose service name
REDIS_HOST=redis
REDIS_PORT=6379

# Telegram
# Bot token from @BotFather — required for Telegram channel integration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# App
# Runtime environment: development | production
ENVIRONMENT=development

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to true to seed mock data into Postgres on first startup (runs only once)
SEED_DATA_ON_STARTUP=true

# Langfuse Observability — self-hosted (runs as part of docker compose up)
# Keys must match LANGFUSE_INIT_PROJECT_* values in docker-compose.yml.
# The Langfuse UI is available at http://localhost:3001 after startup.
# Login: admin@yuno.local / admin  (configurable via LANGFUSE_INIT_USER_* below)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_HOST=http://localhost:3001

# Langfuse local admin account (auto-created on first startup)
LANGFUSE_INIT_USER_EMAIL=admin@yuno.local
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=admin1234
